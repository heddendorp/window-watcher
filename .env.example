# Optional. Defaults are Untergiesing-Harlaching.
LOCATION_LABEL=Untergiesing-Harlaching
LATITUDE=48.0956
LONGITUDE=11.5611

# Optional. Set these if you do not want the app to auto-pick the first tado home
# and the first zone with an inside temperature sensor.
# TADO_HOME_ID=
# TADO_ZONE_ID=

# How much cooler outside must be before opening windows is worth it.
COOLING_MARGIN_C=2
REQUEST_TIMEOUT_MS=5000
# Bright Sky weather calls are cached so dashboard/page refreshes do not hit
# provider rate limits. Defaults to 240000.
# WEATHER_CACHE_MS=240000
# After a Bright Sky 429, reuse cached/history weather for this long. Defaults
# to 600000.
# WEATHER_RATE_LIMIT_BACKOFF_MS=600000
# After a tado 429, pause fresh tado requests for this long and show last saved
# readings. Defaults to 600000.
# TADO_RATE_LIMIT_BACKOFF_MS=600000
# Optional. Defaults to 60000 locally and 300000 on Railway.
# SAMPLE_INTERVAL_MS=60000
# Set to false when Railway Serverless/App Sleeping is enabled and sampling is
# handled by Railway cron through POST /api/sample.
# BACKGROUND_SAMPLER=false
# Secret bearer token for POST /api/sample.
# SAMPLE_TRIGGER_TOKEN=
OUTDOOR_TREND_HOURS=3
OUTDOOR_TREND_DELTA_C=0.3

# Authentication. Auth is off by default. Set both auth flags only after Clerk
# keys are configured and the Railway/browser sign-in UI should be active.
VITE_WINDOW_WATCHER_AUTH=false
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
AUTHORIZED_EMAIL=you@example.com
# WINDOW_WATCHER_AUTH=true

# Persistence. On Railway, attach a volume and set RAILWAY_VOLUME_MOUNT_PATH,
# or explicitly set DATA_DIR. The tado token is stored in this directory.
# DATA_DIR=
# TADO_TOKEN_FILE=
# TADO_TOKEN_JSON=

# Local server port.
PORT=3000
